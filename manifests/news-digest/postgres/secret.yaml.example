# TEMPLATE — do not fill in real values here; this file is committed to git.
#
# Workflow:
#   1. Copy:   cp secret.yaml.example secret.yaml
#   2. Replace the placeholder password with a strong random value
#      (update POSTGRES_PASSWORD and the password in DATABASE_URL to match)
#   3. Seal:   kubeseal --cert ../../../pub-cert.pem --format yaml \
#                < secret.yaml \
#                > sealedsecret.yaml
#   4. Commit sealedsecret.yaml  (NOT the plain .yaml)
#   5. Delete secret.yaml from disk when done
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: news-digest
type: Opaque
stringData:
  POSTGRES_USER: "newsdigest"
  POSTGRES_PASSWORD: "REPLACE_WITH_STRONG_RANDOM_PASSWORD"
  POSTGRES_DB: "newsdigest"
  DATABASE_URL: "postgresql://newsdigest:REPLACE_WITH_STRONG_RANDOM_PASSWORD@postgres-svc:5432/newsdigest"
