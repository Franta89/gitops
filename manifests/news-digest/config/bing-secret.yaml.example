# TEMPLATE — do not fill in real values here; this file is committed to git.
#
# Workflow:
#   1. Copy:   cp bing-secret.yaml.example bing-secret.yaml
#   2. Replace placeholder with:  terraform output -raw bing_api_key   (in infra-terraform)
#   3. Seal:   kubeseal --cert ../../../pub-cert.pem --format yaml \
#                < bing-secret.yaml \
#                > bing-sealedsecret.yaml
#   4. Commit bing-sealedsecret.yaml  (NOT the plain .yaml)
#   5. Delete bing-secret.yaml from disk when done
#
# Note: Bing Search v7 uses key-based auth only — no RBAC/Managed Identity support.
# Documented exception in CLAUDE.md.
apiVersion: v1
kind: Secret
metadata:
  name: bing-secret
  namespace: news-digest
type: Opaque
stringData:
  BING_API_KEY: "REPLACE_WITH_TERRAFORM_OUTPUT_bing_api_key"
