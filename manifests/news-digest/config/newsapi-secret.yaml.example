# TEMPLATE — do not fill in real values here; this file is committed to git.
#
# How to get a NewsAPI key:
#   1. Sign up free at https://newsapi.org/register
#   2. Copy your API key from the dashboard
#
# Workflow:
#   1. Copy:   cp newsapi-secret.yaml.example newsapi-secret.yaml
#   2. Replace REPLACE_WITH_NEWSAPI_KEY with your real key
#   3. Seal:   kubeseal --cert ../../../pub-cert.pem --format yaml \
#                < newsapi-secret.yaml \
#                > newsapi-sealedsecret.yaml
#   4. Commit newsapi-sealedsecret.yaml  (NOT the plain .yaml)
#   5. Delete newsapi-secret.yaml from disk when done
#
# Free tier: 100 req/day, results delayed ~15 min — sufficient for 4 searches/day.
apiVersion: v1
kind: Secret
metadata:
  name: newsapi-secret
  namespace: news-digest
type: Opaque
stringData:
  NEWSAPI_KEY: "REPLACE_WITH_NEWSAPI_KEY"
