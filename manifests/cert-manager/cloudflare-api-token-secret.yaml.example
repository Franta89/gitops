# TEMPLATE — do not fill in real values here; this file is committed to git.
#
# Workflow:
#   1. Copy:   cp cloudflare-api-token-secret.yaml.example cloudflare-api-token-secret.yaml
#   2. Replace REPLACE_WITH_CLOUDFLARE_API_TOKEN with your real token
#   3. Seal:   kubeseal --cert ../../pub-cert.pem --format yaml \
#                < cloudflare-api-token-secret.yaml \
#                > cloudflare-api-token-sealedsecret.yaml
#   4. Commit cloudflare-api-token-sealedsecret.yaml  (NOT the plain .yaml)
#   5. Delete cloudflare-api-token-secret.yaml from disk when done
#
# How to create the Cloudflare API token:
#   Cloudflare dashboard → My Profile → API Tokens → Create Token
#   Template: "Edit zone DNS" → Zone Resources: dailydoseoftech.org only
apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-api-token
  namespace: cert-manager
type: Opaque
stringData:
  api-token: "REPLACE_WITH_CLOUDFLARE_API_TOKEN"
